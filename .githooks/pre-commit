# Pre-commit hook — enforces i18n sync, formatting, and lint checks.
#
# Setup (run once per clone):
#   git config core.hooksPath .githooks

set -euo pipefail

ERRORS=0

# ── i18n key synchronisation ──────────────────────────────────────────────────
STAGED_I18N=$(git diff --cached --name-only --diff-filter=ACMR -- 'src/lib/i18n/' 2>/dev/null || true)

if [ -n "$STAGED_I18N" ]; then
    echo "🌐 i18n files changed — checking key synchronisation…"
    if ! npm run sync:i18n:check --silent 2>&1; then
        echo ""
        echo "❌ i18n keys are out of sync."
        echo "   Run:  npm run sync:i18n:fix"
        ERRORS=1
    else
        echo "✅ i18n keys in sync."
    fi
fi

# ── Frontend formatting (Biome — .ts/.js only; Svelte parsing is partial) ────
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACMR -- '*.ts' '*.js' 2>/dev/null | grep -v node_modules || true)

if [ -n "$STAGED_TS" ]; then
    echo "🎨 Checking frontend formatting…"
    if ! npx biome format --no-errors-on-unmatched $STAGED_TS 2>&1; then
        echo ""
        echo "❌ Frontend formatting issues found."
        echo "   Run:  npm run format"
        ERRORS=1
    else
        echo "✅ Frontend formatting OK."
    fi
fi

# ── Rust formatting ──────────────────────────────────────────────────────────
STAGED_RS=$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs' 2>/dev/null || true)

if [ -n "$STAGED_RS" ]; then
    echo "🦀 Checking Rust formatting…"
    if ! cargo fmt --check 2>&1; then
        echo ""
        echo "❌ Rust formatting issues found."
        echo "   Run:  cargo fmt"
        ERRORS=1
    else
        echo "✅ Rust formatting OK."
    fi
fi

if [ "$ERRORS" -ne 0 ]; then
    echo ""
    echo "❌ Pre-commit checks failed. Fix the issues above and try again."
    exit 1
fi
