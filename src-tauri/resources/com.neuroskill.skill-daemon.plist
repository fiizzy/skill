<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.neuroskill.skill-daemon</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Applications/NeuroSkill.app/Contents/MacOS/skill-daemon.app/Contents/MacOS/skill-daemon</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ProcessType</key>
  <string>Interactive</string>
  <key>StandardOutPath</key>
  <string>/tmp/skill-daemon.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/skill-daemon.err</string>
</dict>
</plist>
